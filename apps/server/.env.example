# Local database file path (default: ./vynex.db)
DB_PATH=./vynex.db

# Server port (default: 3000)
PORT=3000

# Turso cloud sync — leave empty for local-only mode
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui

# How often to sync with Turso in seconds (default: 60)
SYNC_INTERVAL_SECONDS=60
